@prefix jdm: <https://jeroen-demeester.github.io/knowledge-graphs-vocab/vocab.ttl#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.

{ ?x a jdm:Person } => { ?x a foaf:Person }.
{ ?x a jdm:Museum } => { ?x a foaf:Organization }.
{ ?x a jdm:Photograph } => { ?x a foaf:Image }.
{ ?x jdm:depicts ?y } => { ?x foaf:depicts ?y }.
{ ?x jdm:name ?n } => { ?x foaf:name ?n }.
