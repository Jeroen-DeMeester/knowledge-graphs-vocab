    jdm:knows jdm:Jeroen, mnh:Minh .

mnh:Minh
    a mnh:human ;
    mnh:name "Minh Tran" ;
    mnh:knows jdm:Jeroen, dgn:Digna .

jdm:Rijksmuseum
