@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Jeroen
:Jeroen
    a jdm:Person ;
    jdm:name "Jeroen De Meester" ;
    jdm:birthDate "1980-05-22"^^xsd:date ;
    jdm:knows 
        dgn:Digna, 
        <https://minhphtran.github.io/knowledge-graphs-vocab/data.ttl#Minh>,
        <https://drsteiner.github.io/knowledgegraph/person.ttl#Steiny>;
    jdm:sameCourse dgn:Digna, mnh:Minh, lrs:LaurensTobias ;
    jdm:worksAt :Rijksmuseum ;
    jdm:hobby "Triatlon" ;
    jdm:website <https://www.jeroendemeester.be> .

# Digna
dgn:Digna
    a jdm:Person ;
    jdm:name "Digna van Nielen" ;
    jdm:knows :Jeroen, mnh:Minh ;
    jdm:sameCourse :Jeroen, mnh:Minh, lrs:LaurensTobias .

# Minh
mnh:Minh
    a mnh:human ;
    mnh:name "Minh Tran" ;
    mnh:knows :Jeroen, dgn:Digna ;
    jdm:sameCourse :Jeroen, dgn:Digna, lrs:LaurensTobias .

# Laurens Tobias
lrs:LaurensTobias
    a lrs:Person ;
    lrs:name "Laurens Tobias" ;
    jdm:sameCourse :Jeroen, dgn:Digna, mnh:Minh .

# Rijksmuseum
:Rijksmuseum
    a jdm:Museum ;
    jdm:name "Rijksmuseum Amsterdam" ;
    jdm:website <https://www.rijksmuseum.nl> .
