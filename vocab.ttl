@prefix jdm: <https://jeroen-demeester.github.io/knowledge-graphs-vocab/vocab.ttl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

# Classes
jdm:Person
    a rdfs:Class ;
    rdfs:label "Person"@en ;
    rdfs:label "Persoon"@nl ;
    rdfs:comment "A human individual"@en ;
    rdfs:comment "Een menselijk individu"@nl ;
    rdfs:subClassOf foaf:Person ;
    rdfs:subClassOf foaf:Agent .

jdm:Organization
    a rdfs:Class ;
    rdfs:label "Organization"@en ;
    rdfs:label "Organisatie"@nl ;
    rdfs:comment "An organization such as a company, museum, NGO, or other group of people with a common purpose"@en ;
    rdfs:comment "Een organisatie zoals een bedrijf, museum, NGO of andere groep mensen met een gemeenschappelijk doel"@nl ;
    rdfs:subClassOf foaf:Organization ;
    rdfs:subClassOf foaf:Agent .

jdm:Museum
    a rdfs:Class ;
    rdfs:label "Museum"@en ;
    rdfs:label "Museum"@nl ;
    rdfs:comment "A building or institution that collects, preserves, and exhibits objects of artistic, cultural, or scientific importance"@en ;
    rdfs:comment "Een gebouw of instelling die objecten van artistiek, cultureel of wetenschappelijk belang verzamelt, bewaart en tentoonstelt"@nl ;
    rdfs:subClassOf jdm:Organization .

jdm:Photograph
    a rdfs:Class ;
    rdfs:label "Photograph"@en ;
    rdfs:label "Foto"@nl ;
    rdfs:comment "A photograph taken by a photographer"@en ;
    rdfs:comment "Een foto genomen door een fotograaf"@nl .

jdm:Place
    a rdfs:Class ;
    rdfs:label "Place"@en ;
    rdfs:label "Plaats"@nl ;
    rdfs:comment "A location where something is situated or took place"@en ;
    rdfs:comment "Een locatie waar iets zich bevindt of heeft plaatsgevonden"@nl .

# Properties
jdm:name
    a rdf:Property ;
    rdfs:domain jdm:Person, jdm:Organization ;
    rdfs:range xsd:string ;
    rdfs:label "name"@en ;
    rdfs:label "naam"@nl ;
    rdfs:comment "The full name of a person or organization"@en ;
    rdfs:comment "De volledige naam van een persoon of organisatie"@nl ;
    rdfs:subPropertyOf foaf:name .

jdm:birthDate
    a rdf:Property ;
    rdfs:domain jdm:Person ;
    rdfs:range xsd:date ;
    rdfs:label "birth date"@en ;
    rdfs:label "geboortedatum"@nl ;
    rdfs:comment "The birth date of a person"@en ;
    rdfs:comment "De geboortedatum van een persoon"@nl .

jdm:knows
    a rdf:Property ;
    rdfs:domain jdm:Person ;
    rdfs:range jdm:Person ;
    rdfs:label "knows"@en ;
    rdfs:label "kent"@nl ;
    rdfs:comment "Indicates that a person knows another person"@en ;
    rdfs:comment "Geeft aan dat een persoon een andere persoon kent"@nl ;
    rdfs:subPropertyOf foaf:knows .

jdm:worksAt
    a rdf:Property ;
    rdfs:domain jdm:Person ;
    rdfs:range jdm:Organization ;
    rdfs:label "works at"@en ;
    rdfs:label "werkt bij"@nl ;
    rdfs:comment "Indicates the organization where a person works"@en ;
    rdfs:comment "Geeft aan bij welke organisatie een persoon werkt"@nl .

jdm:sameCourse
    a rdf:Property ;
    rdfs:domain jdm:Person ;
    rdfs:range jdm:Person ;
    rdfs:label "same course"@en ;
    rdfs:label "zelfde cursus"@nl ;
    rdfs:comment "Indicates that two persons participate in the same course"@en ;
    rdfs:comment "Geeft aan dat twee personen aan dezelfde cursus deelnemen"@nl .

jdm:hobby
    a rdf:Property ;
    rdfs:domain jdm:Person ;
    rdfs:range xsd:string ;
    rdfs:label "hobby"@en ;
    rdfs:label "hobby"@nl ;
    rdfs:comment "A hobby or leisure activity of a person"@en ;
    rdfs:comment "Een hobby of vrijetijdsactiviteit van een persoon"@nl ;
    rdfs:subPropertyOf foaf:interest .

jdm:website
    a rdf:Property ;
    rdfs:domain jdm:Person, jdm:Organization ;
    rdfs:range xsd:anyURI ;
    rdfs:label "website"@en ;
    rdfs:label "website"@nl ;
    rdfs:comment "The website of a person or organization"@en ;
    rdfs:comment "De website van een persoon of organisatie"@nl ;
    rdfs:subPropertyOf foaf:homepage .

# Photographs properties
jdm:title
    a rdf:Property ;
    rdfs:domain jdm:Photograph ;
    rdfs:range xsd:string ;
    rdfs:label "title"@en ;
    rdfs:label "titel"@nl ;
    rdfs:comment "The title of a photograph"@en ;
    rdfs:comment "De titel van een foto"@nl .

jdm:hasPhotographer
    a rdf:Property ;
    rdfs:domain jdm:Photograph ;
    rdfs:range jdm:Person, jdm:Organization ;
    rdfs:label "has photographer"@en ;
    rdfs:label "heeft fotograaf"@nl ;
    rdfs:comment "Indicates the photographer of a photograph"@en ;
    rdfs:comment "Geeft de fotograaf van een foto aan"@nl .

jdm:depicts
    a rdf:Property ;
    rdfs:domain jdm:Photograph ;
    rdfs:range jdm:Person ;
    rdfs:label "depicts"@en ;
    rdfs:label "beeldt af"@nl ;
    rdfs:comment "Indicates which person is depicted in a photograph"@en ;
    rdfs:comment "Geeft aan welke persoon op de foto staat"@nl .

jdm:takenAt
    a rdf:Property ;
    rdfs:domain jdm:Photograph ;
    rdfs:range jdm:Place ;
    rdfs:label "taken at"@en ;
    rdfs:label "genomen op"@nl ;
    rdfs:comment "Indicates where the photograph was taken"@en ;
    rdfs:comment "Geeft aan waar de foto genomen is"@nl .

jdm:description
    a rdf:Property ;
    rdfs:domain jdm:Photograph ;
    rdfs:range xsd:string ;
    rdfs:label "description"@en ;
    rdfs:label "beschrijving"@nl ;
    rdfs:comment "A description of the photograph"@en ;
    rdfs:comment "Een beschrijving van de foto"@nl .

jdm:image
    a rdf:Property ;
    rdfs:domain jdm:Photograph ;
    rdfs:range xsd:anyURI ;
    rdfs:label "image"@en ;
    rdfs:label "afbeelding"@nl ;
    rdfs:comment "A link to the image file of the photograph"@en ;
    rdfs:comment "Een link naar het afbeeldingsbestand van de foto"@nl .
